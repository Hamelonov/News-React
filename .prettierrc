{
  "semi": false,
  "singleQuote": true,
  "trailingComma": "all",
  "printWidth": 80,
  "tabWidth": 2,
  "plugins": [
    "@trivago/prettier-plugin-sort-imports"
  ],
  "importOrder": [
    "^react",
    ".*/api/(.*)$",
    ".*/hooks/(.*)$",
    ".*/constants/(.*)$",
    ".*/helpers/(.*)$",
    ".*/components/(.*)$",
    "^[./]",
    "\\.css$"
  ],
  "importOrderSeparation": true,
  "importOrderSortSpecifiers": true
}